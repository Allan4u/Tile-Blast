<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <TextView
            android:id="@+id/hsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HIGH SCORES"
            android:textColor="#FFFFD700"
            android:textSize="32sp"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="30dp" />

        <!-- Classic Scores -->
        <TextView
            android:id="@+id/classicLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="— Classic —"
            android:textColor="#FF6A1B9A"
            android:textSize="20sp"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:id="@+id/classicList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="30dp" />

        <!-- Chaos Scores -->
        <TextView
            android:id="@+id/chaosLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="— Chaos —"
            android:textColor="#FFB71C1C"
            android:textSize="20sp"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:id="@+id/chaosList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="30dp" />

        <!-- Back button -->
        <LinearLayout
            android:id="@+id/btnBack"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:background="@drawable/btn_chaos"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="30dp">
            <TextView
                android:id="@+id/btnBackText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Back"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
